generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  INTERNAL
  FOUNDER
  INVESTOR
}

enum DealStage {
  NEW
  REVIEWING
  DILIGENCE
  PASSED
  ACQUIRED
}

model User {
  id          String         @id
  email       String         @unique
  name        String?
  role        UserRole       @default(INTERNAL)
  companySlug String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  ownedDeals  PipelineDeal[] @relation("DealOwner")
  notes       PipelineNote[]
}

model PipelineDeal {
  id           String         @id @default(cuid())
  name         String
  website      String?
  industry     String?
  revenueRange String?
  stage        DealStage      @default(NEW)
  source       String?
  contactName  String?
  contactEmail String?
  summary      String?
  ownerId      String?
  owner        User?          @relation("DealOwner", fields: [ownerId], references: [id])
  notes        PipelineNote[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([stage])
  @@index([updatedAt])
}

model PipelineNote {
  id        String       @id @default(cuid())
  dealId    String
  deal      PipelineDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  authorId  String
  author    User         @relation(fields: [authorId], references: [id])
  body      String
  createdAt DateTime     @default(now())

  @@index([dealId])
}

model InvestorDocument {
  id          String   @id @default(cuid())
  title       String
  description String?
  fileUrl     String?
  quarter     String?
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InternalVenture {
  id              String   @id @default(cuid())
  name            String
  stage           String
  status          String
  thesis          String?
  ownerEmail      String?
  sanityVentureId String?
  internalNotes   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
}

model SearchDocument {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String
  slug      String?
  url       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}
